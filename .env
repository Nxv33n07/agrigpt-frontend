# AgriGPT Frontend — local development
# Vite proxy in vite.config.js routes /api/* to the correct backend.
# In production (Vercel), vercel.json handles the same routing.
# No changes needed between dev and prod.

VITE_AGENT_URL=/api/agent
VITE_FASTAPI_URL=/api/fastapi
VITE_CV_URL=/api/cv
VITE_SPEECH_URL=/api/speech
